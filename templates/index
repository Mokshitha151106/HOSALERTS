        document.getElementById('password').value = '';
        
        document.getElementById('nurseCard').classList.remove('selected');
        document.getElementById('familyCard').classList.remove('selected');
        
        showNotification('Logged out successfully', 'info');
        playBeep('info');
        vibratePattern('info');
    }

