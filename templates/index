<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HOSALERTS - Hospital Medicine</title>

    <!-- Browser Tab Logo -->
    <link rel="icon" type="image/x-icon" href="{{ url_for('static', filename='favicon.ico') }}">
    
    <script src="https://cdnjs.cloudflare.com/ajax/libs/socket.io/4.0.1/socket.io.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        /* Theme Variables */
        :root {
            /* Light theme (default) */
            --bg-gradient-1: #667eea;
            --bg-gradient-2: #764ba2;
            --card-bg: rgba(255, 255, 255, 0.95);
            --text-primary: #2d3748;
            --text-secondary: #4a5568;
            --text-muted: #718096;
            --border-color: #e2e8f0;
            --shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
            --hover-shadow: 0 15px 40px rgba(0, 0, 0, 0.2);
            --input-bg: #ffffff;
            --input-border: #e2e8f0;
            --input-focus: #667eea;
            --success: #4ecdc4;
            --warning: #ffd166;
            --danger: #ff6b6b;
            --info: #667eea;
            --chart-grid: #e2e8f0;
        }

        /* Dark theme */
        [data-theme="dark"] {
            --bg-gradient-1: #1a202c;
            --bg-gradient-2: #2d3748;
            --card-bg: rgba(26, 32, 44, 0.95);
            --text-primary: #f7fafc;
            --text-secondary: #e2e8f0;
            --text-muted: #a0aec0;
            --border-color: #4a5568;
            --shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
            --hover-shadow: 0 15px 40px rgba(0, 0, 0, 0.4);
            --input-bg: #2d3748;
            --input-border: #4a5568;
            --input-focus: #90cdf4;
            --success: #48bb78;
            --warning: #ecc94b;
            --danger: #f56565;
            --info: #90cdf4;
            --chart-grid: #4a5568;
        }

        body {
            background: linear-gradient(135deg, var(--bg-gradient-1), var(--bg-gradient-2));
            min-height: 100vh;
            padding: 20px;
            transition: background 0.3s ease;
            position: relative;
        }

        /* Animated Background */
        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" preserveAspectRatio="none"><path d="M0 0 L100 100 M100 0 L0 100" stroke="rgba(255,255,255,0.05)" stroke-width="0.5"/></svg>');
            pointer-events: none;
            z-index: 0;
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
            position: relative;
            z-index: 1;
        }

        /* ==================== NEW TOP HEADER STYLES ==================== */
        .top-header {
            background: var(--card-bg);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 25px;
            margin-bottom: 20px;
            box-shadow: var(--shadow);
            border: 1px solid var(--border-color);
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .top-header::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, var(--bg-gradient-1), var(--bg-gradient-2), var(--success));
        }

        .logo-wrapper {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 15px;
        }

        .top-logo {
            width: 120px;
            height: 120px;
            object-fit: contain;
            border-radius: 20px;
            background: white;
            padding: 10px;
            box-shadow: var(--hover-shadow);
            transition: all 0.3s ease;
            animation: floatLogo 3s ease-in-out infinite;
        }

        .top-logo:hover {
            transform: scale(1.05);
            box-shadow: 0 20px 40px rgba(0,0,0,0.2);
        }

        @keyframes floatLogo {
            0%, 100% {
                transform: translateY(0);
            }
            50% {
                transform: translateY(-10px);
            }
        }

        .app-title {
            font-size: 48px;
            font-weight: 800;
            background: linear-gradient(135deg, var(--bg-gradient-1), var(--bg-gradient-2), var(--success));
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: 2px;
            text-shadow: var(--shadow);
            margin: 0;
            line-height: 1.2;
        }

        .app-subtitle {
            font-size: 18px;
            color: var(--text-secondary);
            letter-spacing: 3px;
            text-transform: uppercase;
            font-weight: 500;
            position: relative;
            display: inline-block;
            padding: 0 20px;
        }

        .app-subtitle::before,
        .app-subtitle::after {
            content: '';
            position: absolute;
            top: 50%;
            width: 30px;
            height: 2px;
            background: linear-gradient(90deg, var(--bg-gradient-1), var(--bg-gradient-2));
        }

        .app-subtitle::before {
            left: -30px;
        }

        .app-subtitle::after {
            right: -30px;
        }

        .theme-toggle {
            position: absolute;
            top: 20px;
            right: 20px;
            background: var(--input-bg);
            border: 2px solid var(--border-color);
            border-radius: 50px;
            padding: 5px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 10px;
            transition: all 0.3s ease;
            z-index: 10;
        }

        .theme-toggle:hover {
            border-color: var(--info);
            transform: scale(1.05);
        }

        .theme-icon {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            transition: all 0.3s ease;
        }

        .theme-icon.light {
            background: #fbbf24;
            color: #1e293b;
        }

        .theme-icon.dark {
            background: #1e293b;
            color: #fbbf24;
        }

        .theme-icon.active {
            transform: scale(1.1);
            box-shadow: 0 0 15px currentColor;
        }

        /* Offline Alert Banner */
        .offline-banner {
            background: linear-gradient(135deg, #ff6b6b, #ff8e8e);
            color: white;
            padding: 15px 20px;
            border-radius: 10px;
            margin-bottom: 20px;
            display: none;
            align-items: center;
            justify-content: space-between;
            animation: slideDown 0.5s ease;
            border: 2px solid white;
            box-shadow: var(--shadow);
        }

        .offline-banner.active {
            display: flex;
        }

        .offline-content {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .offline-icon {
            font-size: 24px;
            animation: pulse 1s infinite;
        }

        .offline-text {
            font-weight: 600;
        }

        .offline-retry {
            background: white;
            color: #ff6b6b;
            border: none;
            padding: 8px 20px;
            border-radius: 50px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .offline-retry:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }

        @keyframes slideDown {
            from {
                transform: translateY(-100%);
                opacity: 0;
            }
            to {
                transform: translateY(0);
                opacity: 1;
            }
        }

        /* Login Section */
        .login-section {
            background: var(--card-bg);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 30px;
            margin-bottom: 20px;
            box-shadow: var(--shadow);
            border: 1px solid var(--border-color);
            transition: all 0.3s ease;
        }

        .login-section.hidden {
            display: none;
        }

        .login-title {
            font-size: 24px;
            font-weight: bold;
            color: var(--text-primary);
            margin-bottom: 20px;
            text-align: center;
        }

        .login-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
            margin-bottom: 20px;
        }

        .login-card {
            background: var(--input-bg);
            border: 2px solid var(--border-color);
            border-radius: 15px;
            padding: 25px;
            cursor: pointer;
            transition: all 0.3s ease;
            text-align: center;
        }

        .login-card:hover {
            transform: translateY(-5px);
            border-color: var(--info);
            box-shadow: var(--shadow);
        }

        .login-card.selected {
            border-color: var(--success);
            background: linear-gradient(135deg, rgba(78, 205, 196, 0.1), rgba(102, 126, 234, 0.1));
        }

        .login-icon {
            font-size: 48px;
            margin-bottom: 15px;
        }

        .login-card h3 {
            color: var(--text-primary);
            margin-bottom: 10px;
        }

        .login-card p {
            color: var(--text-secondary);
            font-size: 14px;
        }

        .login-form {
            max-width: 400px;
            margin: 0 auto;
            padding: 20px;
            background: var(--input-bg);
            border-radius: 15px;
            border: 1px solid var(--border-color);
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            color: var(--text-primary);
            margin-bottom: 8px;
            font-weight: 600;
        }

        .form-group input,
        .form-group select {
            width: 100%;
            padding: 12px 15px;
            border: 2px solid var(--input-border);
            border-radius: 10px;
            background: var(--input-bg);
            color: var(--text-primary);
            font-size: 16px;
            transition: all 0.3s ease;
        }

        .form-group input:focus,
        .form-group select:focus {
            outline: none;
            border-color: var(--input-focus);
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }

        .login-btn {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, var(--bg-gradient-1), var(--bg-gradient-2));
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .login-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
        }

        .login-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .demo-credentials {
            margin-top: 20px;
            padding: 15px;
            background: var(--input-bg);
            border-radius: 10px;
            border: 1px solid var(--border-color);
            color: var(--text-secondary);
            font-size: 14px;
        }

        .demo-credentials h4 {
            color: var(--text-primary);
            margin-bottom: 10px;
        }

        .demo-credentials ul {
            list-style: none;
            padding: 0;
        }

        .demo-credentials li {
            padding: 5px 0;
            border-bottom: 1px solid var(--border-color);
        }

        /* Dashboard Section */
        .dashboard {
            display: none;
        }

        .dashboard.active {
            display: block;
        }

        /* User Info Bar */
        .user-info {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: var(--card-bg);
            backdrop-filter: blur(10px);
            border-radius: 15px;
            padding: 15px 20px;
            margin-bottom: 20px;
            border: 1px solid var(--border-color);
        }

        .user-details {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .user-avatar {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--bg-gradient-1), var(--bg-gradient-2));
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 24px;
        }

        .user-text h3 {
            color: var(--text-primary);
            margin-bottom: 5px;
        }

        .user-text p {
            color: var(--text-secondary);
            font-size: 14px;
        }

        .logout-btn {
            padding: 10px 20px;
            background: var(--danger);
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .logout-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(255, 107, 107, 0.3);
        }

        /* Stats Grid */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 20px;
        }

        .stat-card {
            background: var(--card-bg);
            backdrop-filter: blur(10px);
            border-radius: 15px;
            padding: 20px;
            box-shadow: var(--shadow);
            border: 1px solid var(--border-color);
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: var(--hover-shadow);
        }

        .stat-icon {
            font-size: 32px;
            margin-bottom: 10px;
        }

        .stat-value {
            font-size: 32px;
            font-weight: bold;
            color: var(--text-primary);
            margin-bottom: 5px;
        }

        .stat-label {
            color: var(--text-secondary);
            font-size: 14px;
        }

        .stat-trend {
            margin-top: 10px;
            padding: 5px 10px;
            border-radius: 20px;
            font-size: 12px;
            display: inline-block;
        }

        .trend-up {
            background: rgba(78, 205, 196, 0.2);
            color: var(--success);
        }

        .trend-down {
            background: rgba(255, 107, 107, 0.2);
            color: var(--danger);
        }

        /* Main Grid */
        .main-grid {
            display: grid;
            grid-template-columns: 1.2fr 0.8fr;
            gap: 20px;
            margin-bottom: 20px;
        }

        /* Patient Card */
        .patient-card {
            background: var(--card-bg);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 20px;
            box-shadow: var(--shadow);
            border: 1px solid var(--border-color);
        }

        .patient-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            flex-wrap: wrap;
            gap: 15px;
        }

        .patient-name {
            font-size: 28px;
            font-weight: bold;
            color: var(--text-primary);
        }

        .patient-badges {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .badge {
            padding: 8px 16px;
            border-radius: 50px;
            font-weight: 600;
            font-size: 14px;
            color: white;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .badge.room {
            background: linear-gradient(135deg, #667eea, #764ba2);
        }

        .badge.doctor {
            background: linear-gradient(135deg, #4ecdc4, #45b7d1);
        }

        .badge.age {
            background: linear-gradient(135deg, #ffd166, #ff6b6b);
        }

        /* Vital Signs */
        .vital-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 15px;
            margin-bottom: 20px;
        }

        .vital-item {
            background: var(--input-bg);
            border: 1px solid var(--border-color);
            border-radius: 15px;
            padding: 15px;
            text-align: center;
            transition: all 0.3s ease;
        }

        .vital-item:hover {
            transform: translateY(-3px);
            box-shadow: var(--shadow);
            border-color: var(--info);
        }

        .vital-icon {
            font-size: 24px;
            margin-bottom: 10px;
        }

        .vital-label {
            font-size: 14px;
            color: var(--text-secondary);
            margin-bottom: 5px;
        }

        .vital-value {
            font-size: 24px;
            font-weight: bold;
            color: var(--text-primary);
        }

        .vital-unit {
            font-size: 12px;
            color: var(--text-muted);
        }

        /* Alert Panel */
        .alert-panel {
            background: var(--card-bg);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 20px;
            box-shadow: var(--shadow);
            border: 1px solid var(--border-color);
        }

        .alert-header {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 20px;
        }

        .alert-icon {
            width: 50px;
            height: 50px;
            background: linear-gradient(135deg, #ff6b6b, #ff8e8e);
            border-radius: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 24px;
        }

        .alert-title {
            font-size: 20px;
            font-weight: bold;
            color: var(--text-primary);
        }

        .alert-count {
            margin-left: auto;
            background: var(--danger);
            color: white;
            padding: 5px 10px;
            border-radius: 50px;
            font-size: 14px;
        }

        .alert-list {
            max-height: 400px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .alert-item {
            background: var(--input-bg);
            border-left: 4px solid var(--danger);
            border-radius: 10px;
            padding: 15px;
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .alert-item:hover {
            transform: translateX(5px);
            box-shadow: var(--shadow);
        }

        .alert-item.critical {
            border-left-color: #dc3545;
            background: linear-gradient(135deg, rgba(220, 53, 69, 0.1), rgba(220, 53, 69, 0.05));
        }

        .alert-patient {
            font-weight: bold;
            color: var(--text-primary);
            margin-bottom: 5px;
        }

        .alert-message {
            color: var(--text-secondary);
            font-size: 14px;
            margin-bottom: 10px;
        }

        .alert-time {
            font-size: 12px;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .alert-actions {
            display: flex;
            gap: 10px;
            margin-top: 10px;
        }

        .alert-btn {
            padding: 8px 15px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            font-size: 12px;
            transition: all 0.3s ease;
        }

        .alert-btn.primary {
            background: var(--danger);
            color: white;
        }

        .alert-btn.primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(255, 107, 107, 0.3);
        }

        .alert-btn.secondary {
            background: var(--input-border);
            color: var(--text-primary);
        }

        .alert-btn.secondary:hover {
            background: var(--text-muted);
        }

        /* Medicine Section */
        .medicine-section {
            background: var(--card-bg);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 20px;
            box-shadow: var(--shadow);
            border: 1px solid var(--border-color);
            margin-bottom: 20px;
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            flex-wrap: wrap;
            gap: 15px;
        }

        .section-title {
            font-size: 20px;
            font-weight: bold;
            color: var(--text-primary);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .add-btn {
            background: linear-gradient(135deg, var(--bg-gradient-1), var(--bg-gradient-2));
            color: white;
            border: none;
            padding: 12px 24px;
            border-radius: 10px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .add-btn:hover {
            transform: translateY(-2px);
            box-shadow: var(--hover-shadow);
        }

        .add-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .medicine-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
        }

        .medicine-card {
            background: var(--input-bg);
            border: 1px solid var(--border-color);
            border-radius: 15px;
            padding: 20px;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .medicine-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, var(--info), var(--success));
        }

        .medicine-card:hover {
            transform: translateY(-5px);
            box-shadow: var(--hover-shadow);
        }

        .medicine-name {
            font-size: 20px;
            font-weight: bold;
            color: var(--text-primary);
            margin-bottom: 5px;
        }

        .medicine-dosage {
            color: var(--text-secondary);
            font-size: 14px;
            margin-bottom: 10px;
        }

        .medicine-time {
            display: inline-block;
            background: linear-gradient(135deg, var(--info), var(--success));
            color: white;
            padding: 5px 15px;
            border-radius: 50px;
            font-size: 12px;
            font-weight: 600;
            margin-bottom: 10px;
        }

        .medicine-status {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 50px;
            font-size: 11px;
            font-weight: 600;
            margin-left: 10px;
        }

        .status-pending {
            background: rgba(255, 209, 102, 0.2);
            color: #ffd166;
        }

        .status-given {
            background: rgba(78, 205, 196, 0.2);
            color: #4ecdc4;
        }

        .status-missed {
            background: rgba(255, 107, 107, 0.2);
            color: #ff6b6b;
        }

        .medicine-instructions {
            color: var(--text-muted);
            font-size: 13px;
            margin: 10px 0;
            padding: 10px;
            background: var(--card-bg);
            border-radius: 8px;
            border-left: 3px solid var(--info);
        }

        .nurse-actions {
            display: flex;
            gap: 10px;
            margin-top: 15px;
        }

        .action-btn {
            flex: 1;
            padding: 10px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            font-size: 13px;
            transition: all 0.3s ease;
        }

        .action-btn.give {
