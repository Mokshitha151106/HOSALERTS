    async function loadFamilyTimeline(patientId) {
        if (!navigator.onLine) return;
        
        try {
            const response = await fetch(`/api/patients/${patientId}/medicines`);
            const medicines = await response.json();
            
            const timeline = document.getElementById('familyTimeline');
            
            if (medicines.length === 0) {
                timeline.innerHTML = '<p style="color: var(--text-muted);">No activity recorded</p>';
                return;
            }
            
            timeline.innerHTML = medicines.slice(0, 10).map(med => {
                const status = med.status;
                const statusClass = status === 'given' ? 'completed' : 
                                   status === 'pending' ? 'pending' : 'missed';
                const statusIcon = status === 'given' ? '✅' : 
                                  status === 'pending' ? '⏳' : '❌';
                
                return `
                    <div class="timeline-item">
                        <div class="timeline-time">${formatTime(med.time)}</div>
                        <div class="timeline-content">
                            <div class="timeline-title">${med.name} ${med.dosage}</div>
                            <div class="timeline-subtitle">${med.instructions || 'No instructions'}</div>
                            ${med.last_given_time ? `
                                <div style="font-size: 11px; color: var(--text-muted); margin-top: 5px;">
                                    Given by ${med.last_given_by} at ${med.last_given_time}
                                </div>
                            ` : ''}
                        </div>
                        <div class="timeline-status status-${statusClass}" title="${status}">${statusIcon}</div>
                    </div>
                `;
            }).join('');
        } catch (error) {
            console.error('Error loading timeline:', error);
        }
    }

    async function updateMedicineStatus(medicineId, status) {
        if (!navigator.onLine) {
            showNotification('Cannot update while offline', 'warning');
            playBeep('warning');
            return;
        }
        
        try {
            const response = await fetch(`/api/medicines/${medicineId}/status`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ 
                    status: status,
                    nurse_name: state.currentUser?.name || 'Nurse'
                })
            });
            
            if (response.ok) {
                if (state.currentPatientId) {
                    await loadMedicines(state.currentPatientId);
                    if (state.userType === 'family') {
                        await loadFamilyTimeline(state.currentPatientId);
                    }
                }
                loadAlerts();
                playBeep('success');
                vibratePattern('success');
                showNotification(`Medicine marked as ${status}`, 'success');
            }
        } catch (error) {
            console.error('Error updating medicine:', error);
            showNotification('Error updating medicine', 'error');
            playBeep('warning');
        }
    }

