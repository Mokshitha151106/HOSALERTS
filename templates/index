    <script>
    // Socket connection with offline handling
    const socket = io({
        reconnection: true,
        reconnectionAttempts: Infinity,
        reconnectionDelay: 1000,
        reconnectionDelayMax: 5000,
        timeout: 20000
    });
    
    // State management
    let state = {
        currentPatientId: null,
        currentUser: null,
        userType: null,
        patients: [],
        alerts: [],
        medicines: [],
        offlineAlerts: [],
        lastSync: null
    };

    // Audio Context
    let audioContext = null;
    let audioInitialized = false;
    let speechSynthesis = window.speechSynthesis;
    let voiceQueue = [];

    // ==================== ENHANCED VOICE ALERT SYSTEM ====================
    
    // Initialize audio on first user interaction
    function initAudio() {
        if (audioInitialized) return true;
        
        try {
            audioContext = new (window.AudioContext || window.webkitAudioContext)();
            audioInitialized = true;
            console.log('Audio initialized successfully');
            
            // Pre-warm speech synthesis
            if (speechSynthesis) {
                speechSynthesis.cancel();
            }
            
            return true;
        } catch (e) {
            console.error('Failed to initialize audio:', e);
            return false;
        }
    }

    // Play beep sound followed by voice
    function playVoiceAlert(message, isCritical = false) {
        if (!initAudio()) return;
        
        // Play beep first
        playBeep(isCritical ? 'critical' : 'warning');
        
        // Then speak after beep
        setTimeout(() => {
            speakText(message);
        }, isCritical ? 600 : 400);
        
        // Vibrate
        vibratePattern(isCritical ? 'critical' : 'warning');
    }

    // Text to speech function
    function speakText(text) {
        if (!window.speechSynthesis) {
            console.log('Speech synthesis not supported');
            return;
        }

        // Cancel any ongoing speech
        speechSynthesis.cancel();

        const utterance = new SpeechSynthesisUtterance(text);
        
        // Get available voices and select a good one
        const voices = speechSynthesis.getVoices();
        const preferredVoice = voices.find(voice => 
            voice.lang.includes('en') && (voice.name.includes('Google') || voice.name.includes('Microsoft'))
        ) || voices[0];
        
        if (preferredVoice) {
            utterance.voice = preferredVoice;
        }
        
        utterance.rate = 0.9;  // Slightly slower for clarity
        utterance.pitch = 1;
        utterance.volume = 1;
        
        // Add to queue
        voiceQueue.push(utterance);
        
        utterance.onend = () => {
            voiceQueue = voiceQueue.filter(u => u !== utterance);
        };
        
        speechSynthesis.speak(utterance);
    }

    // ==================== BEEP SOUND FUNCTIONS ====================
    function playBeep(type = 'info') {
        if (!initAudio()) return;
        
        try {
            if (audioContext.state === 'suspended') {
                audioContext.resume();
            }

            const now = audioContext.currentTime;
            
            const oscillator = audioContext.createOscillator();
            const gainNode = audioContext.createGain();
            
            oscillator.type = 'sine';
            oscillator.connect(gainNode);
            gainNode.connect(audioContext.destination);
            
            switch(type) {
                case 'critical':
                    // Emergency siren pattern - plays 3 times
                    for (let i = 0; i < 3; i++) {
                        const osc = audioContext.createOscillator();
                        const gain = audioContext.createGain();
                        osc.type = 'sine';
                        osc.connect(gain);
                        gain.connect(audioContext.destination);
                        
                        osc.frequency.setValueAtTime(800, now + i * 0.3);
                        osc.frequency.linearRampToValueAtTime(1200, now + i * 0.3 + 0.15);
                        osc.frequency.linearRampToValueAtTime(800, now + i * 0.3 + 0.3);
                        
                        gain.gain.setValueAtTime(0.3, now + i * 0.3);
                        gain.gain.exponentialRampToValueAtTime(0.01, now + i * 0.3 + 0.3);
                        
                        osc.start(now + i * 0.3);
                        osc.stop(now + i * 0.3 + 0.3);
                    }
                    break;
                    
                case 'warning':
                    // Two-tone warning - plays twice
                    for (let i = 0; i < 2; i++) {
                        const osc = audioContext.createOscillator();
                        const gain = audioContext.createGain();
                        osc.type = 'sine';
                        osc.connect(gain);
                        gain.connect(audioContext.destination);
                        
                        osc.frequency.setValueAtTime(600, now + i * 0.25);
                        osc.frequency.linearRampToValueAtTime(400, now + i * 0.25 + 0.2);
                        
                        gain.gain.setValueAtTime(0.25, now + i * 0.25);
                        gain.gain.exponentialRampToValueAtTime(0.01, now + i * 0.25 + 0.2);
                        
                        osc.start(now + i * 0.25);
                        osc.stop(now + i * 0.25 + 0.2);
                    }
                    break;
                    
                case 'success':
                    oscillator.frequency.setValueAtTime(500, now);
                    oscillator.frequency.linearRampToValueAtTime(800, now + 0.15);
                    gainNode.gain.setValueAtTime(0.2, now);
                    gainNode.gain.exponentialRampToValueAtTime(0.01, now + 0.2);
                    oscillator.start(now);
                    oscillator.stop(now + 0.2);
                    break;
                    
                case 'info':
                default:
                    oscillator.frequency.value = 440;
                    gainNode.gain.setValueAtTime(0.15, now);
                    gainNode.gain.exponentialRampToValueAtTime(0.01, now + 0.1);
                    oscillator.start(now);
                    oscillator.stop(now + 0.1);
            }
            
            console.log(`Playing ${type} beep`);
            
        } catch (e) {
            console.error('Error playing beep:', e);
            // Fallback to simple beep using Web Audio
            try {
                const ctx = new (window.AudioContext || window.webkitAudioContext)();
                const osc = ctx.createOscillator();
                const gain = ctx.createGain();
                osc.connect(gain);
                gain.connect(ctx.destination);
                osc.frequency.value = type === 'critical' ? 800 : 440;
                gain.gain.value = 0.1;
                osc.start();
                osc.stop(ctx.currentTime + 0.2);
            } catch (err) {
                console.log('Fallback beep failed');
            }
        }
    }

    // ==================== VIBRATION FUNCTIONS ====================
    function vibrate(pattern) {
        if (!('vibrate' in navigator)) {
            console.log('Vibration not supported on this device');
            return;
        }
        
        try {
            if (Array.isArray(pattern)) {
                navigator.vibrate(pattern);
                console.log('Vibrating with pattern:', pattern);
            } else {
                navigator.vibrate(pattern);
                console.log('Vibrating for', pattern, 'ms');
            }
            
            // Visual vibration feedback
            const container = document.querySelector('.container');
            if (container) {
                container.classList.add('shake');
                setTimeout(() => {
                    container.classList.remove('shake');
                }, 300);
            }
        } catch (e) {
            console.error('Vibration failed:', e);
        }
    }

    function vibratePattern(type) {
        switch(type) {
            case 'critical':
                vibrate([500, 200, 500, 200, 500]);
                break;
            case 'warning':
                vibrate([200, 100, 200, 100, 200]);
                break;
            case 'success':
                vibrate([150, 75, 150]);
                break;
            case 'info':
            default:
                vibrate(100);
        }
    }

    // ==================== OFFLINE ALERT SYSTEM ====================
    
    // Check connection status
    function checkConnection() {
        if (navigator.onLine) {
            document.getElementById('offlineBanner').classList.remove('active');
            playBeep('success');
            showNotification('Back online! Syncing alerts...', 'success');
            
            // Sync offline alerts when back online
            if (state.offlineAlerts.length > 0) {
                syncOfflineAlerts();
            }
        } else {
            document.getElementById('offlineBanner').classList.add('active');
            playBeep('warning');
            vibratePattern('warning');
        }
    }

    // Listen for online/offline events
    window.addEventListener('online', checkConnection);
    window.addEventListener('offline', checkConnection);

    // Store alert offline
    function storeOfflineAlert(alert) {
        const offlineAlert = {
            ...alert,
            id: Date.now() + Math.random(),
            storedAt: new Date().toISOString()
        };
        
        state.offlineAlerts.push(offlineAlert);
        
        // Store in localStorage for persistence
        localStorage.setItem('hosalerts_offline_alerts', JSON.stringify(state.offlineAlerts));
        
        // Show offline notification with voice
        showOfflineNotification(offlineAlert);
    }

    // Show offline notification with voice
    function showOfflineNotification(alert) {
        const voiceAlert = document.getElementById('voiceAlert');
        if (!voiceAlert) return;
        
        const title = document.getElementById('voiceTitle');
        const message = document.getElementById('voiceMessage');
        const room = document.getElementById('voiceRoom');
        
        const isCritical = alert.severity === 'critical' || alert.type === 'escalation';
        
        title.textContent = isCritical ? '🚨 CRITICAL OFFLINE ALERT' : '📴 OFFLINE ALERT';
        message.textContent = `${alert.patient_name || 'Unknown'}: ${alert.message || 'Medication alert'}`;
        room.textContent = `📍 Room ${alert.room_number || '---'} (Stored Locally)`;
        
        voiceAlert.className = `voice-alert ${isCritical ? 'escalation' : ''} active`;
        
        // Play voice alert with beep
        const voiceMessage = isCritical ? 
            `CRITICAL ALERT! ${alert.patient_name} in room ${alert.room_number} needs immediate attention. ${alert.message}` :
            `Alert for ${alert.patient_name} in room ${alert.room_number}. ${alert.message}`;
        
        playVoiceAlert(voiceMessage, isCritical);
        
        setTimeout(() => {
            voiceAlert.classList.remove('active');
        }, 10000);
    }

    // Sync offline alerts when back online
    async function syncOfflineAlerts() {
        if (!navigator.onLine || state.offlineAlerts.length === 0) return;
        
        try {
            const response = await fetch('/api/offline-sync', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    alerts: state.offlineAlerts,
                    last_sync: state.lastSync
                })
            });
            
            const data = await response.json();
            
            if (data.success) {
                // Clear synced alerts
                localStorage.removeItem('hosalerts_offline_alerts');
                state.offlineAlerts = [];
                state.lastSync = new Date().toISOString();
                
                showNotification(`Synced ${data.synced} offline alerts`, 'success');
                playBeep('success');
                
                // Check for any missed alerts from server
                if (data.missed_alerts && data.missed_alerts.length > 0) {
                    data.missed_alerts.forEach(alert => {
                        showVoiceAlert(alert, alert.type === 'escalation');
                    });
                }
            }
        } catch (error) {
            console.error('Sync failed:', error);
        }
    }

