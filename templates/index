    async function login() {
        const username = document.getElementById('username').value;
        const password = document.getElementById('password').value;
        
        if (!username || !password) {
            showNotification('Please enter username and password', 'error');
            playBeep('warning');
            vibratePattern('warning');
            return;
        }
        
        const loginBtn = document.getElementById('loginBtn');
        loginBtn.disabled = true;
        loginBtn.textContent = 'Logging in...';
        
        try {
            const response = await fetch('/api/login', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    username: username,
                    password: password,
                    user_type: selectedUserType
                })
            });
            
            const data = await response.json();
            
            if (data.success) {
                state.currentUser = data.user;
                state.userType = data.user.user_type;
                
                document.getElementById('loginSection').style.display = 'none';
                document.getElementById('dashboard').classList.add('active');
                
                document.getElementById('userName').textContent = data.user.name;
                document.getElementById('userType').textContent = 
                    data.user.user_type === 'nurse' ? '👩‍⚕️ Nurse' : '👨‍👩‍👧 Family Member';
                document.getElementById('userAvatar').textContent = 
                    data.user.user_type === 'nurse' ? '👩‍⚕️' : '👨‍👩‍👧';
                
                loadMyPatients();
                loadStats();
                loadAlerts();
                
                document.getElementById('addMedicineBtn').style.display = 
                    data.user.user_type === 'nurse' ? 'flex' : 'none';
                
                document.getElementById('familyView').style.display = 
                    data.user.user_type === 'family' ? 'block' : 'none';
                
                showNotification(`Welcome, ${data.user.name}!`, 'success');
                playBeep('success');
                vibratePattern('success');
            } else {
                showNotification('Invalid credentials', 'error');
                playBeep('warning');
                vibratePattern('warning');
            }
        } catch (error) {
            console.error('Login error:', error);
            showNotification('Login failed - ' + (navigator.onLine ? 'Server error' : 'You are offline'), 'error');
            playBeep('warning');
        } finally {
            loginBtn.disabled = false;
            loginBtn.textContent = 'Login';
        }
    }

    async function logout() {
        await fetch('/api/logout', { method: 'POST' }).catch(() => {});
        
        state.currentUser = null;
