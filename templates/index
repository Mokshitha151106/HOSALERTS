            '<p style="text-align: center; color: var(--text-muted); grid-column: 1/-1;">Select a patient to view medications</p>';
    }

    // ==================== NOTIFICATION FUNCTIONS ====================
    function showVoiceAlert(data, isEscalation = false) {
        const voiceAlert = document.getElementById('voiceAlert');
        const title = document.getElementById('voiceTitle');
        const message = document.getElementById('voiceMessage');
        const room = document.getElementById('voiceRoom');
        
        title.textContent = isEscalation ? '🚨 URGENT ALERT' : '🔊 Medication Alert';
        message.textContent = isEscalation ? 
            `${data.patient_name} - ${data.medicine_name} overdue by ${data.minutes_overdue} min` :
            `${data.patient_name} - ${data.message}`;
        room.textContent = `📍 Room ${data.room_number}`;
        
        voiceAlert.className = `voice-alert ${isEscalation ? 'escalation' : ''} active`;
        
        // Play voice alert with beep
        const voiceMessage = isEscalation ?
            `CRITICAL! ${data.patient_name} in room ${data.room_number} is ${data.minutes_overdue} minutes overdue for ${data.medicine_name}. Please respond immediately.` :
            `${data.patient_name} in room ${data.room_number} has a medication alert. ${data.message}`;
        
        playVoiceAlert(voiceMessage, isEscalation);
        
        setTimeout(() => {
            voiceAlert.classList.remove('active');
        }, 10000);
    }

    function closeVoiceAlert() {
        document.getElementById('voiceAlert').classList.remove('active');
        if (speechSynthesis) {
            speechSynthesis.cancel();
        }
        if ('vibrate' in navigator) {
            navigator.vibrate(0);
        }
    }

    function showNotification(message, type = 'info') {
        console.log(`[${type}] ${message}`);
        
        if (type === 'error') {
            alert(message);
        }
    }

    // ==================== MODAL FUNCTIONS ====================
    function openAddMedicineModal() {
        document.getElementById('addMedicineModal').classList.add('active');
        playBeep('info');
    }

    function closeAddMedicineModal() {
        document.getElementById('addMedicineModal').classList.remove('active');
        document.getElementById('medName').value = '';
        document.getElementById('medDosage').value = '';
        document.getElementById('medTime').value = '';
        document.getElementById('medInstructions').value = '';
    }

    // ==================== UTILITY FUNCTIONS ====================
    function formatTime(time) {
        if (!time) return '';
        const [hours, minutes] = time.split(':');
        const hour = parseInt(hours);
        const ampm = hour >= 12 ? 'PM' : 'AM';
        const hour12 = hour % 12 || 12;
        return `${hour12}:${minutes} ${ampm}`;
    }

    // ==================== SOCKET LISTENERS ====================
    socket.on('connect', () => {
        console.log('Connected to server');
        showNotification('Connected to server', 'success');
        playBeep('success');
        checkConnection();
        
        // Request any missed alerts
        socket.emit('request_offline_alerts', { last_sync: state.lastSync });
    });

    socket.on('new_alert', (alert) => {
        if (!navigator.onLine) {
            storeOfflineAlert(alert);
        } else if (state.currentUser) {
            loadAlerts();
            
            // Play voice alert with beep
            const voiceMessage = alert.severity === 'critical' ?
                `CRITICAL ALERT! ${alert.patient_name} in room ${alert.room_number}. ${alert.message}` :
                `Alert for ${alert.patient_name} in room ${alert.room_number}. ${alert.message}`;
            
            playVoiceAlert(voiceMessage, alert.severity === 'critical');
            
            showNotification(`New alert: ${alert.message}`, 'warning');
        }
    });

    socket.on('voice_alert', (data) => {
        if (!navigator.onLine) {
            storeOfflineAlert(data);
        } else {
            showVoiceAlert(data);
        }
    });

    socket.on('voice_alert_escalation', (data) => {
        if (!navigator.onLine) {
            storeOfflineAlert(data);
        } else {
            showVoiceAlert(data, true);
        }
    });

    socket.on('offline_alerts', (data) => {
        if (data.alerts && data.alerts.length > 0) {
            data.alerts.forEach(alert => {
                showVoiceAlert(alert, alert.type === 'escalation');
            });
            showNotification(`Received ${data.alerts.length} missed alerts`, 'info');
        }
    });

    socket.on('medicine_updated', (medicine) => {
        if (medicine.patient_id === state.currentPatientId) {
            loadMedicines(state.currentPatientId);
            if (state.userType === 'family') {
                loadFamilyTimeline(state.currentPatientId);
            }
        }
    });

    socket.on('medicine_added', (medicine) => {
        if (medicine.patient_id === state.currentPatientId) {
            loadMedicines(state.currentPatientId);
            showNotification('New medicine added', 'success');
            playBeep('success');
        }
    });

    socket.on('alert_updated', () => {
        loadAlerts();
    });

    socket.on('disconnect', () => {
        console.log('Disconnected from server');
        showNotification('Disconnected from server', 'error');
        playBeep('warning');
        checkConnection();
    });

    socket.on('reconnect', () => {
        console.log('Reconnected to server');
        showNotification('Reconnected to server', 'success');
        playBeep('success');
        checkConnection();
        syncOfflineAlerts();
    });

    socket.on('reconnect_attempt', () => {
        console.log('Attempting to reconnect...');
    });

    socket.on('reconnect_error', (error) => {
        console.error('Reconnection error:', error);
    });

    socket.on('reconnect_failed', () => {
        console.error('Failed to reconnect');
        showNotification('Failed to reconnect. Please refresh.', 'error');
    });

    // ==================== INITIALIZATION ====================
    document.addEventListener('DOMContentLoaded', () => {
        console.log('HOSALERTS initialized');
        checkConnection();
        
        // Load offline alerts from storage
        const stored = localStorage.getItem('hosalerts_offline_alerts');
        if (stored) {
            try {
                state.offlineAlerts = JSON.parse(stored);
                if (state.offlineAlerts.length > 0) {
                    showNotification(`${state.offlineAlerts.length} offline alerts pending`, 'info');
                }
            } catch (e) {
                console.error('Failed to load offline alerts:', e);
            }
        }
        
        // Load last sync time
        state.lastSync = localStorage.getItem('hosalerts_last_sync');
    });

    // Save last sync time before unload
    window.addEventListener('beforeunload', () => {
        if (state.lastSync) {
            localStorage.setItem('hosalerts_last_sync', state.lastSync);
        }
    });

    // Refresh data periodically when online
    setInterval(() => {
        if (state.currentUser && navigator.onLine) {
            loadStats();
            loadAlerts();
        }
    }, 30000);

    // Make functions globally available
    window.toggleTheme = toggleTheme;
    window.selectUserType = selectUserType;
    window.login = login;
    window.logout = logout;
    window.changePatient = changePatient;
    window.acknowledgeAlert = acknowledgeAlert;
    window.updateMedicineStatus = updateMedicineStatus;
    window.openAddMedicineModal = openAddMedicineModal;
    window.closeAddMedicineModal = closeAddMedicineModal;
    window.addMedicine = addMedicine;
    window.closeVoiceAlert = closeVoiceAlert;
    window.testNotification = testNotification;
    window.checkConnection = checkConnection;
    </script>
</body>
</html>
